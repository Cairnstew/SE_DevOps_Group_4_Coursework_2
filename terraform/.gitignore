.envrc
.direnv/
.aws/
.ssh-config

# Local .terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude all .tfvars files (may contain secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI config files
.terraformrc
terraform.rc

# Ignore plan output files
*.tfplan

# Ignore lock file (optional: keep if you want reproducibility)
.terraform.lock.hcl

# Ignore logs
*.log

# macOS / Windows junk
.DS_Store
Thumbs.db